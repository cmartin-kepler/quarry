/target

# Fetched / generated corpus (large, reproducible via scripts/)
/corpus

# Input corpus: track the folder structure, ignore the documents dropped in.
/input/*
!/input/README.md
!/input/.gitkeep

# Scratch parse output (e.g. `parse --out tmp/out`)
/tmp/

# LaTeX build artifacts + bridge outputs (regenerated by scripts/latex/build.sh).
# The .tex, .cells.json, and build.sh are source and ARE tracked.
scripts/latex/*.aux
scripts/latex/*.log
scripts/latex/*.out
scripts/latex/*.pdf
scripts/latex/*.qdoc
scripts/latex/filing.truth.json

# Python: uv-managed env (uv.lock IS tracked for reproducibility)
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# OCR language data (downloaded by tesseract/liteparse)
*.traineddata

# ENVIRONMENT VARIABLES
.env